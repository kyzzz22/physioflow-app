{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhysioFlow",
  "version": "0.4.0",
  "identifier": "com.physioflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PhysioFlow",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Education",
    "shortDescription": "Visual experiment workflow system",
    "longDescription": "PhysioFlow builds, runs, and exports behavioral and physiological experiment workflows with local file storage."
  }
}
